
{
  "expo": {
    "name": "PolyArticle",
    "slug": "flashfeed",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",

    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "android": {
      "package": "com.rohan.flashfeed2",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": []
    },

    "ios": {
      "bundleIdentifier": "com.rohan.flashfeed2",
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "plugins": [
      "expo-secure-store",
      [
        "react-native-google-mobile-ads",
        {
          "android_app_id": "ca-app-pub-2345974289373242~3123605011",
          "ios_app_id": "ca-app-pub-2345974289373242~2759641888"
        }
      ]
    ],

    "assetBundlePatterns": ["**/*"],

    "extra": {
      "eas": {
        "projectId": "9ab60785-2236-4a55-96c5-1df3e484d1f8"
      }
    },

    "owner": "rohan141101"
  }
}